# ================================
# Barbershop Booking Agent Config
# ================================

# Application
APP_NAME=""
ENVIRONMENT="development"  # development, staging, production
DEBUG=true

# LLM Configuration
LLM_PROVIDER="azure_openai"  # "openai" or "azure_openai"

# OpenAI Configuration
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4"
OPENAI_TEMPERATURE=0.7

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY="your-azure-openai-api-key-here"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_API_VERSION="2025-03-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-4"

# FastAPI Configuration
API_HOST="0.0.0.0"
API_PORT=8005
API_RELOAD=true

# Database Configuration
DATABASE_URL="sqlite+aiosqlite:///./barbershop.db"
# For PostgreSQL use:
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/barbershop"

# Database Pool Settings (for PostgreSQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# CORS Settings
CORS_ORIGINS=["http://localhost:8005", "http://localhost:3000"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# Operating Hours (JSON format - by day of week, 0=Monday, 6=Sunday)
BUSINESS_HOURS='{"0": {"open": "09:00", "close": "20:00"}, "1": {"open": "09:00", "close": "20:00"}, "2": {"open": "09:00", "close": "20:00"}, "3": {"open": "09:00", "close": "20:00"}, "4": {"open": "09:00", "close": "20:00"}, "5": {"open": "09:00", "close": "20:00"}, "6": {"open": "10:00", "close": "18:00"}}'

# Booking Configuration
BOOKING_ADVANCE_DAYS=14  # How many days in advance can customers book
CANCELLATION_NOTICE_HOURS=24  # Required notice for cancellations
SAME_DAY_BOOKING_CUTOFF_HOUR=14  # Latest hour for same-day bookings (24-hour format)

# Logging
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
