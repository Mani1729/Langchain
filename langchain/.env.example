# Environment Variables for LangChain Learning

# Azure OpenAI Configuration
# Note: The tutorials are pre-configured with Azure OpenAI credentials
# If you want to override, set these environment variables:
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_api_key_here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_MODEL_NAME=gpt-4o

# Optional: Regular OpenAI API Key (if you want to switch)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic Claude API Key
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: LangSmith for Monitoring and Debugging
# Sign up at: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=langchain-learning

# Optional: Other LLM Providers
# Add keys for other providers as needed
# HUGGINGFACEHUB_API_TOKEN=your_hf_token
# COHERE_API_KEY=your_cohere_key
